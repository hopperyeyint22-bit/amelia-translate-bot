# split words
word_list = list(set(words.split()))

# create Myanmar meanings (basic)
mm_dict = {}

for w in word_list:
    mm_dict[w] = f"{w} (မြန်မာအဓိပ္ပါယ်ထည့်ရန်)"

# save json
with open("mm_dict.json", "w", encoding="utf-8") as f:
    json.dump(mm_dict, f, ensure_ascii=False, indent=2)

print("✅ Dictionary created!")
